# Upstash Redis / Vercel Redis integration
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Legacy Vercel KV names are still accepted by src/lib/kv.ts
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Lightning-talk voting admin access (32+ random bytes recommended)
ADMIN_TOKEN=

# Optional — used by src/app/layout.tsx and sitemap
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_GA_ID=

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://<project>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-key>
